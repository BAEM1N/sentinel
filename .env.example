# === 필수 ===
OPENAI_API_KEY=sk-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# === 모델 설정 ===
SENTINEL_MODEL=gpt-5.4
SENTINEL_FALLBACK_MODEL=gpt-5.3-instant

# === 프로바이더 설정 (기본: openai) ===
# SENTINEL_PROVIDER=openai
# SENTINEL_PROVIDER=anthropic     # → ANTHROPIC_API_KEY 필요
# SENTINEL_PROVIDER=gemini        # → GOOGLE_API_KEY 필요
# SENTINEL_PROVIDER=ollama        # → 로컬 Ollama 서버
# SENTINEL_PROVIDER=vllm          # → 로컬 vLLM 서버
# SENTINEL_PROVIDER=lmstudio      # → 로컬 LM Studio
# SENTINEL_PROVIDER=openrouter    # → OPENROUTER_API_KEY 필요
# SENTINEL_PROVIDER=qwen          # → DASHSCOPE_API_KEY 필요
# SENTINEL_PROVIDER=glm           # → GLM_API_KEY 필요

# 커스텀 엔드포인트 (OpenAI 호환 프로바이더용)
# SENTINEL_BASE_URL=http://localhost:8000/v1

# 프로바이더 공통 API 키 (설정 시 프로바이더별 기본 env var 대신 사용)
# SENTINEL_API_KEY=sk-...

# === 에이전트 설정 ===
SENTINEL_REPORTS_DIR=./reports
SENTINEL_SKILLS_DIR=./skills/
SENTINEL_RUN_LIMIT=30
# SENTINEL_FALLBACK_MODEL=          # 비우면 프로바이더별 기본 fallback 자동 적용

# === 스케줄러 ===
# SENTINEL_AUTO_HTML=true           # 스케줄러 보고서에 HTML도 자동 생성
# SENTINEL_ENABLE_SCHEDULER=true    # false로 설정하면 스케줄러 비활성화 (멀티 인스턴스 배포 시)
# SENTINEL_TIMEZONE=UTC             # 스케줄러 시간대 표시

# === 알림 (Slack) ===
# SENTINEL_SLACK_WEBHOOK=https://hooks.slack.com/services/...

# === 알림 (Telegram) ===
# SENTINEL_TELEGRAM_BOT_TOKEN=123456:ABC...
# SENTINEL_TELEGRAM_CHAT_ID=123456789

# === 알림 (Email / SMTP) ===
# SENTINEL_SMTP_HOST=smtp.gmail.com
# SENTINEL_SMTP_PORT=587
# SENTINEL_SMTP_USER=you@gmail.com
# SENTINEL_SMTP_PASS=app-password
# SENTINEL_EMAIL_TO=team@company.com
# SENTINEL_EMAIL_FROM=sentinel@company.com

# === LangSmith 트레이싱 (선택) ===
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=sentinel
